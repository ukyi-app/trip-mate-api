# 로컬 개발용 예시. .env로 복사해 값 채우고 DB/캐시 conn은 .env.local에 두고 `bun run dev`.
# (배포 시크릿 봉인은 deploy/.env.example — 별개)
PORT=8080                              # 리슨 포트(로컬 임의; 차트 ports.http=8080)
BETTER_AUTH_SECRET=dev-only-change-me-min-32-chars-0000
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
WEB_ORIGINS=http://localhost:5173
INVITE_TOKEN_TTL_HOURS=168
USE_SECURE_COOKIES=false               # prod=true(HTTPS), 로컬 http만 false
# FX provider keys (opt-in — 미설정 시 skip)
OXR_APP_ID=
CURRENCYAPI_KEY=

# ── DB/캐시 conn URL(머신별) → .env.local 에 설정 ──
# prod는 conn 핸들(db-trip-mate-conn·cache-trip-mate-conn)이 envFrom으로 자동 주입하므로 불필요.
# TRIP_MATE_DATABASE_URL=postgres://trip:trip@localhost:5432/trip_mate
# TRIP_MATE_MIGRATE_DATABASE_URL=        # 비면 TRIP_MATE_DATABASE_URL
# TRIP_MATE_REDIS_URL=redis://localhost:6379
