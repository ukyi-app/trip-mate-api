# 봉인(prod) 소스. .env로 복사해 prod 값 채우고 `bun run secret:seal`
#   → deploy/trip-mate-api-secrets.sealed.yaml (create-app이 읽는 봉인본).
# 로컬 실행은 .env.local에서 오버라이드(Bun이 .env 위에 .env.local을 덮어씀).
# ⚠️ DB/Redis conn URL은 .env(봉인)에 넣지 말 것 — prod는 conn 핸들(db/cache-trip-mate-conn)이
#    envFrom으로 자동 주입. 로컬 conn은 .env.local에.

# ── prod 값(봉인 대상) ──
BETTER_AUTH_SECRET=                                  # openssl rand -base64 32 (32자+)
BETTER_AUTH_URL=https://trip-mate-api.home.ukyi.app
WEB_ORIGINS=                                         # 프론트 origin(콤마구분)
USE_SECURE_COOKIES=true
INVITE_TOKEN_TTL_HOURS=168
OXR_APP_ID=                                          # 자동환율(선택)
# CURRENCYAPI_KEY=                                   # 자동환율 폴백(선택)
# GOOGLE_CLIENT_ID=                                  # 소셜 로그인(선택)
# GOOGLE_CLIENT_SECRET=

# ── 로컬 오버라이드 → .env.local (gitignore, 봉인 안 됨) ──
# BETTER_AUTH_URL=http://localhost:3000
# USE_SECURE_COOKIES=false
# TRIP_MATE_DATABASE_URL=postgres://trip:trip@localhost:5432/trip_mate
# TRIP_MATE_MIGRATE_DATABASE_URL=
# TRIP_MATE_REDIS_URL=redis://localhost:6379
