PORT=8080                              # 리슨 포트(차트 ports.http=8080; 로컬 임의)
# DB/캐시 conn 키는 homelab create-database/cache 산출명 그대로(name=trip-mate → TRIP_MATE_*).
TRIP_MATE_DATABASE_URL=postgres://trip:trip@localhost:5432/trip_mate  # 런타임(prod=pgbouncer 풀러)
TRIP_MATE_MIGRATE_DATABASE_URL=        # boot self-migrate 직결(prod=pg-rw; 비면 TRIP_MATE_DATABASE_URL)
BETTER_AUTH_SECRET=dev-only-change-me-min-32-chars-0000
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 세션 secondaryStorage·FX 캐시(ioredis)
TRIP_MATE_REDIS_URL=redis://localhost:6379
WEB_ORIGINS=http://localhost:5173
INVITE_TOKEN_TTL_HOURS=168
USE_SECURE_COOKIES=false               # prod=true(HTTPS), 로컬 http만 false
# FX provider keys (opt-in 실계약 smoke 테스트용 — 미설정 시 skip)
OXR_APP_ID=
CURRENCYAPI_KEY=
