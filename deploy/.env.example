# trip-mate-api-secrets 봉인 전용 템플릿.
# 사용: 이 파일을 deploy/.env로 복사 → 값 채움 → `bun run secret:seal`
#   → deploy/trip-mate-api-secrets.sealed.yaml 생성(kubeseal 필요). 평문 deploy/.env는 .gitignore로 미추적.
# ⚠️ DB/Redis URL은 절대 넣지 않는다 — db-trip-mate-conn·cache-trip-mate-conn(create-database/cache 산출
#    conn 핸들)이 values.yaml envFrom으로 공급한다. 여기에 넣으면 중복·혼선.
# (로컬 개발용 .env는 레포 루트 .env.example 참고 — 그쪽은 TRIP_MATE_DATABASE_URL 등 포함, 별개다.)

# ── 필수 ──
BETTER_AUTH_SECRET=                                 # openssl rand -base64 32 (32자 이상)
BETTER_AUTH_URL=https://trip-mate-api.home.ukyi.app # 앱이 서빙되는 실제 URL
WEB_ORIGINS=                                        # 프론트 origin(콤마구분 다중) — CORS/CSRF/trustedOrigins 정확 일치

# ── 권장(prod) ──
USE_SECURE_COOKIES=true
INVITE_TOKEN_TTL_HOURS=168

# ── 선택: 쓸 때만 주석 해제(빈/주석 줄은 봉인 대상에서 제외됨) ──
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# OXR_APP_ID=
# CURRENCYAPI_KEY=
